VITE_SUPABASE_ANON_KEY=your-anon-key

# Pickup location shown in the app and in order confirmation emails
VITE_PICKUP_ADDRESS=123 Your St, Apt 4B, City, State
VITE_PICKUP_NOTES=Ring doorbell #4, I'll come down

# Add these in Vercel: Project Settings → Environment Variables
