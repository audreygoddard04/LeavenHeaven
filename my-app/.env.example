# Supabase - required for auth and database
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Pickup location shown in the app and in order confirmation emails
VITE_PICKUP_ADDRESS=1083 Western Road
VITE_PICKUP_NOTES=Pickup is Sundays at 2:00 PM — look for the stand out front!

# Optional: if orders.pickup_window_id is required, paste a row UUID from Table Editor → pickup_windows
# VITE_PICKUP_WINDOW_ID=00000000-0000-0000-0000-000000000000

# Stripe checkout (optional — enables payment before order is saved)
# Point this at your deployed Express server (server/ folder in this repo)
# Leave blank to skip Stripe and save orders directly in Supabase
# VITE_API_URL=https://your-server.railway.app

# Add these in Vercel: Project Settings → Environment Variables
